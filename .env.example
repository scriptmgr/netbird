# Copy this file to .env and set values before running install.sh.
# Variables set here override the script's built-in defaults.
# This file is safe to commit — it contains no secrets.

# Public hostname for the NetBird stack (must be a valid FQDN)
# NB_DOMAIN=vpn.example.com

# External HTTPS port (default: 443)
# NB_EXTERNAL_PORT=443

# Keycloak realm name (default: netbird)
# NB_ORG=netbird

# Admin e-mail address for Keycloak
# NB_EMAIL=admin@example.com

# From address for outbound Keycloak e-mails
# NB_EMAIL_FROM=no-reply@example.com

# Display name for outbound Keycloak e-mails
# NB_EMAIL_FROM_NAME=NetBird

# Container timezone (default: UTC)
# NB_TIMEZONE=UTC

# Installation root on the host (default: /opt/netbird)
# NB_ROOT=/opt/netbird
